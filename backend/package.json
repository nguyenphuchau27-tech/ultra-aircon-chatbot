{
  "name": "aircon-startup-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{ recursive:true, force:true })\" && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/main.js",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "test": "jest --runInBand",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "type-check": "tsc --noEmit --incremental false -p tsconfig.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm run typeorm -- migration:generate src/database/migrations/ChangeLatLonToFloat -d src/database/data-source.ts",
    "migration:create": "pnpm run typeorm -- migration:create src/database/migrations",
    "migration:run": "pnpm run typeorm -- migration:run -d src/database/data-source.ts",
    "migration:revert": "pnpm run typeorm -- migration:revert -d src/database/data-source.ts",
    "migrate:passwords": "ts-node -r tsconfig-paths/register scripts/migrate-plain-passwords.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-jaeger": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.8.1",
    "typeorm": "^0.3.28",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/testing": "^11.1.18",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.11.30",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^10.1.0",
    "jest": "29.7.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "29.1.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.3.3"
  },
  "overrides": {
    "tar": "^7.5.12"
  }
}